{
  "name": "xac-sankey",
  "version": "1.0.18",
  "description": "X Atlas Consortia Sankey",
  "keywords": [
    "sankey",
    "data",
    "medical",
    "dbmi"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x-atlas-consortia/data-sankey.git"
  },
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "watch": {
    "dist": "src/lib/js/*.js"
  },
  "scripts": {
    "dist": "rm -rf dist && NODE_ENV=production node ./node_modules/xac-esbuild/index.js -s=src/lib/ -o=dist/ -banner=package.json -log=1 -t='**/*.{js,css,html}'",
    "css": "stylus --include-css --compress -w ./src/styles/xac-sankey.styl -o ./src/lib/xac-sankey.css",
    "example": "serve ./dist",
    "dev": "serve ./src/lib -p 3003",
    "watch": "npm-watch",
    "all": "npm-run-all --parallel watch dev css"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3"
  },
  "devDependencies": {
    "esbuild": "0.27.3",
    "glob": "^13.0.6",
    "npm-run-all": "^4.1.5",
    "npm-watch": "^0.13.0",
    "serve": "^14.2.5",
    "stylus": "^0.64.0",
    "xac-esbuild": "github:x-atlas-consortia/xac-esbuild#1.0.0"
  }
}
